{
	"name": "@acdh-oeaw/euralex26",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "^24"
	},
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"build": "run-s build:site generate:search-index",
		"build:site": "astro build",
		"dev": "astro dev",
		"format:check": "prettier . \"!./@(content|public)/**\" --cache --cache-location ./.prettiercache --check --ignore-path ./.gitignore",
		"format:fix": "pnpm run format:check --write",
		"generate:search-index": "pagefind --site ./dist/client/",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --cache --ext .astro,.js,.ts,.tsx --ignore-path ./.gitignore",
		"lint:code:fix": "pnpm run lint:code:check --fix",
		"lint:styles:check": "stylelint \"./**/*.@(astro|css)\" --cache --ignore-path ./.gitignore",
		"lint:styles:fix": "pnpm run lint:styles:check --fix",
		"preinstall": "npx only-allow pnpm",
		"prepare": "run-s setup",
		"setup": "is-ci || simple-git-hooks",
		"start": "astro preview",
		"sync": "astro sync",
		"test": "exit 0",
		"test:e2e": "exit 0",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"types:check": "astro check",
		"validate": "run-p format:check lint:check types:check test test:e2e"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^0.1.12",
		"@acdh-oeaw/validate-env": "^0.0.3",
		"@astrojs/mdx": "^3.1.9",
		"@astrojs/node": "^8.3.4",
		"@astrojs/react": "^3.6.3",
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "3.1.6",
		"@floating-ui/dom": "^1.8.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/red-hat-display": "5.2.8",
		"@iconify-json/lucide": "^1.2.117",
		"@iconify-json/simple-icons": "^1.2.90",
		"@keystatic/astro": "^5.2.0",
		"@keystatic/core": "^0.5.51",
		"@mdx-js/mdx": "^3.1.1",
		"@pagefind/default-ui": "^1.5.2",
		"@shikijs/rehype": "^1.29.2",
		"@sindresorhus/slugify": "^2.2.1",
		"astro": "^4.16.19",
		"astro-icon": "^1.1.5",
		"cva": "1.0.0-beta.1",
		"date-fns": "^3.6.0",
		"estree-util-value-to-estree": "^3.5.0",
		"hast-util-heading": "^3.0.0",
		"hast-util-heading-rank": "^3.0.0",
		"hast-util-to-string": "^3.0.1",
		"lucide-react": "^0.436.0",
		"mdast-util-mdx-jsx": "^3.2.0",
		"nodemailer": "^6.10.1",
		"pagefind": "^1.5.2",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rehype-slug": "^6.0.0",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-mdx-frontmatter": "^5.2.0",
		"remark-smartypants": "^3.0.2",
		"retext-smartypants": "^6.2.0",
		"satori": "^0.10.14",
		"sharp": "^0.33.5",
		"shiki": "^1.29.2",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"valibot": "^0.39.0",
		"vfile": "^6.0.3",
		"vite": "^5.4.21"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^1.0.10",
		"@acdh-oeaw/eslint-config-astro": "^1.0.14",
		"@acdh-oeaw/eslint-config-playwright": "^1.0.10",
		"@acdh-oeaw/eslint-config-react": "^1.0.12",
		"@acdh-oeaw/prettier-config": "^2.0.1",
		"@acdh-oeaw/stylelint-config": "^2.3.2",
		"@acdh-oeaw/tsconfig": "^1.5.1",
		"@astrojs/check": "^0.9.9",
		"@astrojs/ts-plugin": "^1.10.10",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/typography": "^0.5.20",
		"@types/estree": "^1.0.9",
		"@types/hast": "^3.0.5",
		"@types/mdast": "^4.0.4",
		"@types/mdx": "^2.0.14",
		"@types/node": "^24.13.3",
		"@types/nodemailer": "^6.4.24",
		"@types/react": "18.3.4",
		"@types/react-dom": "^18.3.7",
		"@typescript-eslint/eslint-plugin": "7.18.0",
		"@typescript-eslint/parser": "7.18.0",
		"autoprefixer": "^10.5.4",
		"axe-core": "^4.12.1",
		"axe-playwright": "^2.2.2",
		"ci-info": "^4.4.0",
		"dotenv": "^16.6.1",
		"dotenv-expand": "^11.0.7",
		"eslint": "^8.57.1",
		"eslint-plugin-tailwindcss": "^3.18.3",
		"is-ci": "^3.0.1",
		"lint-staged": "^15.5.2",
		"npm-run-all2": "^6.2.6",
		"postcss": "^8.5.19",
		"prettier": "^3.9.5",
		"prettier-plugin-astro": "^0.14.1",
		"schema-dts": "^1.1.5",
		"simple-git-hooks": "^2.13.1",
		"stylelint": "^16.26.1",
		"tailwindcss": "^3.4.19",
		"type-fest": "^4.41.0",
		"typescript": "^5.9.3"
	},
	"browserslist": {
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		],
		"production": [
			">=0.75%",
			"not dead",
			"not op_mini all"
		]
	},
	"pnpm": {
		"overrides": {
			"@types/react": "18.3.4"
		},
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"simple-git-hooks",
			"unrs-resolver"
		]
	},
	"eslintConfig": {
		"extends": [
			"@acdh-oeaw/eslint-config",
			"@acdh-oeaw/eslint-config/strict",
			"@acdh-oeaw/eslint-config-astro",
			"@acdh-oeaw/eslint-config-react",
			"@acdh-oeaw/eslint-config-playwright",
			"plugin:eslint-plugin-tailwindcss/recommended"
		],
		"settings": {
			"tailwindcss": {
				"callees": [
					"cn",
					"variants"
				],
				"classRegex": "^class(:list)?$"
			}
		}
	},
	"lint-staged": {
		"*.astro": [
			"eslint --cache --fix",
			"stylelint --cache --fix",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.css": [
			"stylelint --cache --fix",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.@(js|ts|tsx)": [
			"eslint --cache --fix",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.!(astro|css|js|ts|tsx),!./@(content|public)/**": "prettier --cache --cache-location ./.prettiercache --ignore-unknown --write"
	},
	"postcss": {
		"plugins": {
			"tailwindcss": {},
			"autoprefixer": {}
		}
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm exec lint-staged"
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config",
		"rules": {
			"declaration-property-value-no-unknown": [
				true,
				{
					"ignoreProperties": {
						"/.+/": [
							"/theme\\(.+\\)/"
						]
					}
				}
			]
		}
	}
}
