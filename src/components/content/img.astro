---
import type { HTMLAttributes } from "astro/types";
import { Image } from "astro:assets";

import { getImageImport } from "@/lib/get-image-import";

interface Props extends HTMLAttributes<"img"> {}

const { title = "", alt = "", src, width, height, ...rest } = Astro.props;
---

{
	src != null ? (
		src.startsWith("/") ? (
			<Image
				{...rest}
				title={title}
				alt={alt}
				src={getImageImport(src)}
				widths={[640, 960, 1280, 1600]}
				sizes="(max-width: 768px) 100vw, (max-width: 1280px) min(100vw, 80rem), 1280px"
				format="webp"
				quality={82}
			/>
		) : (
			<img {...rest} title={title} alt={alt} height={height} src={src} width={width} />
		)
	) : null
}
